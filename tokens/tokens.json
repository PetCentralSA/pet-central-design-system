{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Pet Central design tokens. Single source of truth for every Pet Central interface — main site, dashboard, campaign-intelligence, and any agent-generated output.",
  "$version": "1.0.0",
  "brand": {
    "primary":      { "$value": "#48658D", "$type": "color", "$description": "Core navy. Body text, secondary surfaces, default brand colour." },
    "primary-deep": { "$value": "#163E6F", "$type": "color", "$description": "Deep navy. Headings, dark surfaces, high-emphasis text." },
    "cream":        { "$value": "#FFFCFB", "$type": "color", "$description": "Warm white. Page backgrounds, inverse text on dark fills." },
    "terracotta":   { "$value": "#F87644", "$type": "color", "$description": "Accent. Use sparingly for emphasis, never as a flood fill." }
  },
  "functional": {
    "info":     { "bg": { "$value": "#E6F1FB", "$type": "color" }, "border": { "$value": "#185FA5", "$type": "color" }, "text": { "$value": "#0C447C", "$type": "color" } },
    "success":  { "bg": { "$value": "#DEECE4", "$type": "color" }, "border": { "$value": "#2A7D62", "$type": "color" }, "text": { "$value": "#0D4434", "$type": "color" } },
    "warning":  { "bg": { "$value": "#FAEEDA", "$type": "color" }, "border": { "$value": "#BA7517", "$type": "color" }, "text": { "$value": "#633806", "$type": "color" } },
    "danger":   { "bg": { "$value": "#FCEBEB", "$type": "color" }, "border": { "$value": "#A32D2D", "$type": "color" }, "text": { "$value": "#791F1F", "$type": "color" } },
    "seasonal": { "bg": { "$value": "#EEEDFE", "$type": "color" }, "border": { "$value": "#534AB7", "$type": "color" }, "text": { "$value": "#3C3489", "$type": "color" } }
  },
  "neutral": {
    "cream": {
      "0":   { "$value": "#FFFFFE", "$type": "color", "$description": "Pure white surface." },
      "50":  { "$value": "#FFFBF7", "$type": "color", "$description": "Default warm page background." },
      "100": { "$value": "#FEF7EF", "$type": "color", "$description": "Inset / hover warm surface." },
      "200": { "$value": "#FDEEDF", "$type": "color", "$description": "Highlight warm tint." }
    },
    "navy": {
      "0":   { "$value": "#FBFCFD", "$type": "color", "$description": "Cool near-white surface." },
      "50":  { "$value": "#E2E6ED", "$type": "color", "$description": "Default border / divider." },
      "100": { "$value": "#A3B2C6", "$type": "color", "$description": "Muted text, icon strokes, hairline emphasis." },
      "200": { "$value": "#48658D", "$type": "color", "$description": "Aliased to brand.primary." }
    }
  },
  "radius": {
    "sm":   { "$value": "4px",    "$type": "dimension" },
    "md":   { "$value": "8px",    "$type": "dimension" },
    "lg":   { "$value": "12px",   "$type": "dimension" },
    "xl":   { "$value": "16px",   "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension" }
  },
  "shadow": {
    "none": { "$value": "none",                                     "$type": "shadow" },
    "sm":   { "$value": "0 1px 2px rgba(22, 62, 111, 0.06)",        "$type": "shadow", "$description": "Hover lift, sticky-nav separator." },
    "md":   { "$value": "0 4px 12px rgba(22, 62, 111, 0.08)",       "$type": "shadow", "$description": "Dropdowns, popovers." },
    "lg":   { "$value": "0 12px 32px rgba(22, 62, 111, 0.12)",      "$type": "shadow", "$description": "Modals, sheets." },
    "xl":   { "$value": "0 24px 64px rgba(22, 62, 111, 0.16)",      "$type": "shadow", "$description": "Full-screen overlays, splash." }
  },
  "focus": {
    "ring-color":  { "$value": "#48658D", "$type": "color" },
    "ring-width":  { "$value": "3px",     "$type": "dimension" },
    "ring-offset": { "$value": "2px",     "$type": "dimension" }
  },
  "z-index": {
    "base":     { "$value": 0,   "$type": "number" },
    "dropdown": { "$value": 100, "$type": "number" },
    "sticky":   { "$value": 200, "$type": "number" },
    "fixed":    { "$value": 300, "$type": "number" },
    "overlay":  { "$value": 400, "$type": "number" },
    "modal":    { "$value": 500, "$type": "number" },
    "popover":  { "$value": 600, "$type": "number" },
    "toast":    { "$value": 700, "$type": "number" },
    "tooltip":  { "$value": 800, "$type": "number" }
  },
  "content-width": {
    "narrow":  { "$value": "640px",  "$type": "dimension", "$description": "Prose, blog posts, long-form reading." },
    "default": { "$value": "1120px", "$type": "dimension", "$description": "Marketing pages, standard app shell." },
    "wide":    { "$value": "1440px", "$type": "dimension", "$description": "Dashboards, product grids, data tables." },
    "full":    { "$value": "100%",   "$type": "dimension", "$description": "Edge-to-edge hero, full-bleed imagery." }
  },
  "breakpoint": {
    "sm": { "$value": "480px",  "$type": "dimension", "$description": "Large phone, landscape mobile." },
    "md": { "$value": "768px",  "$type": "dimension", "$description": "Tablet portrait, small laptop." },
    "lg": { "$value": "1024px", "$type": "dimension", "$description": "Desktop — default target." },
    "xl": { "$value": "1440px", "$type": "dimension", "$description": "Wide desktop, dashboards." }
  },
  "chart": {
    "1": { "$value": "#48658D", "$type": "color", "$description": "Brand primary navy — first series." },
    "2": { "$value": "#F87644", "$type": "color", "$description": "Terracotta — second series." },
    "3": { "$value": "#2A7D62", "$type": "color", "$description": "Pine." },
    "4": { "$value": "#BA7517", "$type": "color", "$description": "Amber." },
    "5": { "$value": "#534AB7", "$type": "color", "$description": "Violet." },
    "6": { "$value": "#185FA5", "$type": "color", "$description": "Royal." },
    "7": { "$value": "#A3B2C6", "$type": "color", "$description": "Navy muted." },
    "8": { "$value": "#163E6F", "$type": "color", "$description": "Primary deep — least emphasis." }
  },
  "icon": {
    "xs": { "$value": "12px", "$type": "dimension", "$description": "Inline body, dense tables." },
    "sm": { "$value": "16px", "$type": "dimension", "$description": "Form fields, buttons, chips." },
    "md": { "$value": "20px", "$type": "dimension", "$description": "Default — nav, card headers." },
    "lg": { "$value": "24px", "$type": "dimension", "$description": "Empty states, callouts." },
    "xl": { "$value": "32px", "$type": "dimension", "$description": "Hero panels, onboarding." }
  },
  "logo": {
    "xs": { "$value": "16px", "$type": "dimension", "$description": "Inline mentions, dense UI." },
    "sm": { "$value": "24px", "$type": "dimension", "$description": "Nav bars, compact headers." },
    "md": { "$value": "36px", "$type": "dimension", "$description": "Standard nav, footers, signatures." },
    "lg": { "$value": "56px", "$type": "dimension", "$description": "Page heroes, about pages." },
    "xl": { "$value": "88px", "$type": "dimension", "$description": "Splash screens, brand moments." }
  },
  "motion": {
    "duration": {
      "fast": { "$value": "120ms", "$type": "duration" },
      "base": { "$value": "200ms", "$type": "duration" },
      "slow": { "$value": "320ms", "$type": "duration" }
    },
    "easing": {
      "out":   { "$value": "cubic-bezier(0.16, 1, 0.3, 1)",    "$type": "cubicBezier" },
      "inout": { "$value": "cubic-bezier(0.65, 0, 0.35, 1)",   "$type": "cubicBezier" }
    }
  },
  "type": {
    "family": {
      "header":  { "$value": "Kefir, Jost, system-ui, sans-serif",            "$type": "fontFamily", "$description": "Headings only. Distinctive display weight." },
      "ui":      { "$value": "Jost, system-ui, -apple-system, sans-serif",    "$type": "fontFamily", "$description": "Body, UI, default." },
      "numbers": { "$value": "Inter, system-ui, sans-serif",                  "$type": "fontFamily", "$description": "Numerals, data, tabular figures." },
      "mono":    { "$value": "JetBrains Mono, ui-monospace, monospace",       "$type": "fontFamily", "$description": "Code, design tokens, technical labels." }
    }
  },
  "dark-mode": {
    "surface":       { "$value": "#0D2A4D",                       "$type": "color", "$description": "Page background in dark mode." },
    "card":          { "$value": "#163E6F",                       "$type": "color", "$description": "Default card surface — same as brand.primary-deep." },
    "elevated":      { "$value": "#1E4C7F",                       "$type": "color", "$description": "Raised card, hover state." },
    "text":          { "$value": "#FFFCFB",                       "$type": "color", "$description": "Default text — brand cream." },
    "text-muted":    { "$value": "rgba(255, 252, 251, 0.68)",     "$type": "color" },
    "text-dim":      { "$value": "rgba(255, 252, 251, 0.45)",     "$type": "color" },
    "border":        { "$value": "rgba(255, 252, 251, 0.14)",     "$type": "color" },
    "border-strong": { "$value": "rgba(255, 252, 251, 0.28)",     "$type": "color" }
  }
}
